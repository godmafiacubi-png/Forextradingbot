# Safe example environment. Copy to .env locally and fill in private values.
# Defaults keep order routing in dry-run mode.

# Profile: default, demo, or live
SETTINGS_PROFILE=default

# Execution gate: live trading requires BOTH DRY_RUN=false and LIVE_TRADING_CONFIRMED=true.
DRY_RUN=true
LIVE_TRADING_CONFIRMED=false

# MetaTrader 5 connection (leave blank/zero for tests and dry-run development)
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Order controls
ORDER_MAGIC=123456
ORDER_DEVIATION=20
MAX_LOT_SIZE=2.0

# Dashboard/alerts
DASHBOARD_PORT=5001
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
