# Copy this file to .env and fill in real values before live trading.
# Never commit secrets or production account credentials.

# Trading mode: AGGRESSIVE uses monitoring.web_dashboard_aggressive;
# DEFAULT/CONSERVATIVE and other values use monitoring.web_dashboard.
BOT_MODE=DEFAULT

# MetaTrader 5 account connection
MT5_LOGIN=12345678
MT5_PASSWORD=replace_with_your_password
MT5_SERVER=YourBroker-Server
MT5_PATH=

# Optional notifications
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime controls
DASHBOARD_PORT=5001
DRY_RUN=true
LOG_LEVEL=INFO
