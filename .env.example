# Copy this file to .env and fill in real values locally only.
# Never commit secrets, production account credentials, or broker tokens.

# Profile: default is fail-safe. Use demo for forward testing; live still needs
# DRY_RUN=false and LIVE_TRADING_CONFIRMED=true.
SETTINGS_PROFILE=default
BOT_MODE=DEFAULT
BOT_VERSION=V8.0

# MetaTrader 5 account connection (safe placeholders)
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Optional notifications
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime controls
DASHBOARD_PORT=5001
LOG_LEVEL=INFO

# Execution safety: fail-closed defaults.
DRY_RUN=true
LIVE_TRADING_CONFIRMED=false
ORDER_MAGIC=123456
ORDER_DEVIATION=20
MAX_LOT_SIZE=2.0
